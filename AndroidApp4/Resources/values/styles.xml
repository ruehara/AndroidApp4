<?xml version="1.0" encoding="utf-8"?>
<resources>
  <style name="Widget.AndroidApp4" parent="android:Widget" />

  <style name="TextAppearance.AndroidApp4.SectionTitle" parent="TextAppearance.Material3.TitleLarge">
    <item name="android:textStyle">bold</item>
  </style>

  <style name="TextAppearance.AndroidApp4.SectionBody" parent="TextAppearance.Material3.BodyMedium">
    <item name="android:alpha">0.78</item>
  </style>

  <style name="TextAppearance.AndroidApp4.TopAppBar.Title" parent="TextAppearance.Material3.TitleLarge">
    <item name="android:textColor">?attr/colorOnPrimary</item>
  </style>

  <style name="TextAppearance.AndroidApp4.TopAppBar.Subtitle" parent="TextAppearance.Material3.BodyMedium">
    <item name="android:textColor">?attr/colorOnPrimary</item>
    <item name="android:alpha">0.82</item>
  </style>

  <style name="Widget.AndroidApp4.AppBarLayout" parent="Widget.AndroidApp4">
    <item name="android:background">?attr/colorPrimary</item>
    <item name="android:elevation">1dp</item>
    <item name="statusBarForeground">?attr/colorPrimary</item>
  </style>

  <style name="Widget.AndroidApp4.MaterialToolbar" parent="Widget.AndroidApp4">
    <item name="android:background">?attr/colorPrimary</item>
    <item name="android:paddingStart">2dp</item>
    <item name="android:paddingEnd">2dp</item>
    <item name="navigationIconTint">?attr/colorOnPrimary</item>
    <item name="titleTextAppearance">@style/TextAppearance.AndroidApp4.TopAppBar.Title</item>
    <item name="subtitleTextAppearance">@style/TextAppearance.AndroidApp4.TopAppBar.Subtitle</item>
  </style>

  <style name="Widget.AndroidApp4.Card" parent="Widget.Material3.CardView.Elevated">
    
    <item name="elevation">10dp</item>
    <item name="cardUseCompatPadding">true</item>
    <item name="cardCornerRadius">28dp</item>
  </style>
</resources>